<script>
    (() => {
        /* =====================================================
           Mini AgentSpeak(L) interpreter — didactic subset
           ===================================================== */

        // ---------- Tokenizer ----------
        function tokenize(src) {
            src = src.replace(/\/\*[\s\S]*?\*\//g, ' ').replace(/\/\/[^\n]*/g, ' ');
            const tokens = [];
            let i = 0;
            const isW = (c) => /\s/.test(c);
            const isDigit = (c) => c >= '0' && c <= '9';
            const isIdent = (c) => /[A-Za-z0-9_]/.test(c);
            while (i < src.length) {
                const c = src[i];
                if (isW(c)) { i++; continue; }
                if (c === '"') {
                    let j = i + 1, s = '';
                    while (j < src.length && src[j] !== '"') { s += src[j]; j++; }
                    tokens.push({ t: 'str', v: s }); i = j + 1; continue;
                }
                if (isDigit(c) || (c === '-' && isDigit(src[i + 1]) && ['(', ',', ''].includes(tokens.at(-1)?.t === 'punc' ? tokens.at(-1).v : ''))) {
                    let j = i, n = '';
                    if (src[j] === '-') { n = '-'; j++; }
                    while (j < src.length && (isDigit(src[j]) || src[j] === '.')) {
                        if (src[j] === '.' && !isDigit(src[j + 1])) break;
                        n += src[j]; j++;
                    }
                    tokens.push({ t: 'num', v: parseFloat(n) }); i = j; continue;
                }
                if (c === '.' && /[a-z]/.test(src[i + 1] || '')) {
                    let j = i + 1, s = '';
                    while (j < src.length && isIdent(src[j])) { s += src[j]; j++; }
                    tokens.push({ t: 'internal', v: s }); i = j; continue;
                }
                if (/[a-z]/.test(c)) {
                    let j = i, s = '';
                    while (j < src.length && isIdent(src[j])) { s += src[j]; j++; }
                    tokens.push({ t: s === 'not' ? 'not' : 'atom', v: s }); i = j; continue;
                }
                if (/[A-Z_]/.test(c)) {
                    let j = i, s = '';
                    while (j < src.length && isIdent(src[j])) { s += src[j]; j++; }
                    tokens.push({ t: 'var', v: s }); i = j; continue;
                }
                // multi-char operators
                const three = src.slice(i, i + 3);
                const two = src.slice(i, i + 2);
                if (three === '\\==') { tokens.push({ t: 'op', v: '\\==' }); i += 3; continue; }
                if (['<-', '<=', '>=', '==', ':-'].includes(two)) {
                    tokens.push({ t: two === '<-' ? 'arrow' : 'op', v: two }); i += 2; continue;
                }
                if ('()[]+-!~?:;,&|<>=*/'.includes(c)) {
                    const type = '<>='.includes(c) ? 'op' : 'punc';
                    tokens.push({ t: type, v: c }); i++; continue;
                }
                if (c === '.') { tokens.push({ t: 'dot', v: '.' }); i++; continue; }
                throw new Error(`Unexpected character "${c}"`);
            }
            return tokens;
        }

        // ---------- Parser ----------
        function parse(src) {
            const tk = tokenize(src);
            let p = 0;
            const peek = () => tk[p];
            const next = () => tk[p++];
            const expect = (t, v) => {
                const x = next();
                if (!x || x.t !== t || (v !== undefined && x.v !== v))
                    throw new Error(`Expected ${v || t} near token ${p}`);
                return x;
            };

            function parseTerm() {
                const x = next();
                if (!x) throw new Error('Unexpected end of program');
                if (x.t === 'num') return { k: 'num', v: x.v };
                if (x.t === 'str') return { k: 'str', v: x.v };
                if (x.t === 'var') return { k: 'var', v: x.v };
                if (x.t === 'punc' && x.v === '~') {
                    const negTerm = parseTerm();
                    return { k: 'neg', t: negTerm };
                }
                if (x.t === 'punc' && x.v === '[') {
                    const items = [];
                    let tail = null;
                    if (!(peek() && peek().t === 'punc' && peek().v === ']')) {
                        items.push(parseExpr());
                        while (peek() && peek().t === 'punc' && peek().v === ',') {
                            next();
                            items.push(parseExpr());
                        }
                        if (peek() && peek().t === 'punc' && peek().v === '|') {
                            next();
                            tail = parseExpr();
                        }
                    }
                    expect('punc', ']');
                    return { k: 'list', items, tail };
                }
                if (x.t === 'atom') {
                    if (peek() && peek().t === 'punc' && peek().v === '(') {
                        next();
                        const args = [];
                        if (!(peek().t === 'punc' && peek().v === ')')) {
                            args.push(parseExpr());
                            while (peek() && peek().t === 'punc' && peek().v === ',') { next(); args.push(parseExpr()); }
                        }
                        expect('punc', ')');
                        return { k: 'struct', f: x.v, args };
                    }
                    return { k: 'struct', f: x.v, args: [] };
                }
                if (x.t === 'punc' && x.v === '(') {
                    const e = parseExpr();
                    expect('punc', ')');
                    return e;
                }
                throw new Error(`Unexpected token "${x.v}"`);
            }

            // arithmetic expressions (for contexts/args): term (op term)*
            function parseExpr() {
                let left = parseTerm();
                while (peek() && ((peek().t === 'punc' && ['+', '-', '*', '/'].includes(peek().v)))) {
                    const op = next().v;
                    const right = parseTerm();
                    left = { k: 'arith', op, l: left, r: right };
                }
                return left;
            }

            function parseCondition() {
                if (peek() && peek().t === 'not') {
                    next();
                    return { k: 'not', c: parseCondition() };
                }
                const left = parseExpr();
                if (peek() && peek().t === 'op') {
                    const op = next().v;
                    const right = parseExpr();
                    return { k: 'cmp', op, l: left, r: right };
                }
                return { k: 'lit', t: left };
            }

            function parseContext() {
                const conds = [parseCondition()];
                while (peek() && peek().t === 'punc' && peek().v === '&') { next(); conds.push(parseCondition()); }
                return conds;
            }

            function parseBodyFormula() {
                const x = peek();
                if (x.t === 'punc' && x.v === '!') { next(); return { k: 'achieve', t: parseTerm() }; }
                if (x.t === 'punc' && x.v === '?') { next(); return { k: 'test', t: parseTerm() }; }
                if (x.t === 'punc' && x.v === '+') { next(); return { k: 'addB', t: parseTerm() }; }
                if (x.t === 'punc' && x.v === '-') { next(); return { k: 'delB', t: parseTerm() }; }
                if (x.t === 'internal') {
                    const name = next().v;
                    const args = [];
                    if (peek() && peek().t === 'punc' && peek().v === '(') {
                        next();
                        if (!(peek().t === 'punc' && peek().v === ')')) {
                            args.push(parseExpr());
                            while (peek() && peek().t === 'punc' && peek().v === ',') {
                                next();
                                if (peek().t === 'punc' && peek().v === '!') { next(); args.push({ k: 'goalref', t: parseTerm() }); }
                                else args.push(parseExpr());
                            }
                        }
                        expect('punc', ')');
                    }
                    return { k: 'internal', name, args };
                }
                return { k: 'action', t: parseTerm() };
            }

            function parseBody() {
                const fs = [parseBodyFormula()];
                while (peek() && peek().t === 'punc' && peek().v === ';') { next(); fs.push(parseBodyFormula()); }
                return fs;
            }

            const beliefs = [], goals = [], plans = [], rules = [];
            while (p < tk.length) {
                const x = peek();
                if (x.t === 'punc' && (x.v === '+' || x.v === '-')) {
                    // plan
                    const sign = next().v;
                    let goal = false;
                    if (peek().t === 'punc' && peek().v === '!') { next(); goal = true; }
                    const head = parseTerm();
                    let context = [{ k: 'lit', t: { k: 'struct', f: 'true', args: [] } }];
                    let body = [];
                    if (peek() && peek().t === 'punc' && peek().v === ':') { next(); context = parseContext(); }
                    if (peek() && peek().t === 'arrow') { next(); body = parseBody(); }
                    expect('dot');
                    plans.push({ sign, goal, head, context, body });
                } else if (x.t === 'punc' && x.v === '!') {
                    next();
                    const g = parseTerm();
                    expect('dot');
                    goals.push(g);
                } else {
                    const h = parseTerm();
                    if (peek() && peek().t === 'op' && peek().v === ':-') {
                        next();
                        const body = parseContext();
                        expect('dot');
                        rules.push({ head: h, body });
                    } else {
                        expect('dot');
                        beliefs.push(h);
                    }
                }
            }
            return { beliefs, goals, plans, rules };
        }

        // ---------- Unification ----------
        function walk(t, s) {
            while (t && t.k === 'var' && s.has(t.v)) t = s.get(t.v);
            return t;
        }

        function unify(a, b, s) {
            a = walk(a, s); b = walk(b, s);
            if (a.k === 'var') { const s2 = new Map(s); s2.set(a.v, b); return s2; }
            if (b.k === 'var') { const s2 = new Map(s); s2.set(b.v, a); return s2; }
            if (a.k === 'num' && b.k === 'num') return a.v === b.v ? s : null;
            if (a.k === 'str' && b.k === 'str') return a.v === b.v ? s : null;
            if (a.k === 'neg' && b.k === 'neg') return unify(a.t, b.t, s);
            if (a.k === 'list' && b.k === 'list') {
                const emptyList = () => ({ k: 'list', items: [], tail: null });
                const isClosedEmpty = (l) => l.k === 'list' && l.items.length === 0 && !l.tail;

                let cur = s;
                const aItems = [...(a.items || [])];
                const bItems = [...(b.items || [])];

                while (aItems.length && bItems.length) {
                    cur = unify(aItems.shift(), bItems.shift(), cur);
                    if (!cur) return null;
                }

                const restA = aItems.length
                    ? { k: 'list', items: aItems, tail: a.tail || null }
                    : (a.tail || emptyList());
                const restB = bItems.length
                    ? { k: 'list', items: bItems, tail: b.tail || null }
                    : (b.tail || emptyList());

                // [] cannot unify with a guaranteed non-empty list remainder.
                if (isClosedEmpty(restA) && restB.k === 'list' && restB.items.length > 0) return null;
                if (isClosedEmpty(restB) && restA.k === 'list' && restA.items.length > 0) return null;

                if (isClosedEmpty(restA) && isClosedEmpty(restB)) return cur;
                return unify(restA, restB, cur);
            }
            if (a.k === 'struct' && b.k === 'struct') {
                if (a.f !== b.f || a.args.length !== b.args.length) return null;
                let cur = s;
                for (let i = 0; i < a.args.length; i++) {
                    cur = unify(a.args[i], b.args[i], cur);
                    if (!cur) return null;
                }
                return cur;
            }
            return null;
        }

        function evalArith(t, s) {
            t = walk(t, s);
            if (t.k === 'num') return t.v;
            if (t.k === 'arith') {
                const l = evalArith(t.l, s), r = evalArith(t.r, s);
                if (l === null || r === null) return null;
                switch (t.op) {
                    case '+': return l + r;
                    case '-': return l - r;
                    case '*': return l * r;
                    case '/': return r === 0 ? null : l / r;
                }
            }
            return null;
        }

        function fmt(t, s) {
            t = walk(t, s || new Map());
            if (!t) return '?';
            if (t.k === 'num') return String(t.v);
            if (t.k === 'str') return t.v;
            if (t.k === 'var') return t.v;
            if (t.k === 'neg') return `~${fmt(t.t, s)}`;
            if (t.k === 'arith') { const v = evalArith(t, s || new Map()); return v === null ? '?' : String(v); }
            if (t.k === 'goalref') return '!' + fmt(t.t, s);
            if (t.k === 'list') {
                const items = t.items.map((a) => fmt(a, s));
                if (t.tail) {
                    const tailFmt = fmt(t.tail, s);
                    return `[${items.join(', ')}${items.length ? ' | ' : '| '}${tailFmt}]`;
                }
                return `[${items.join(', ')}]`;
            }
            if (t.k === 'struct') return t.args.length ? `${t.f}(${t.args.map((a) => fmt(a, s)).join(', ')})` : t.f;
            return '?';
        }

        // ---------- Engine ----------
        function run(src, log) {
            const { beliefs, goals, plans, rules } = parse(src);
            const bb = []; // belief base (ground structs)
            let steps = 0;
            const MAX = 600;
            const tick = () => { if (++steps > MAX) throw new Error(`Step limit reached (${MAX}) — possible infinite recursion`); };

            function* solve(conds, idx, s) {
                if (idx >= conds.length) { yield s; return; }
                const c = conds[idx];
                tick();
                if (c.k === 'lit') {
                    const lit = walk(c.t, s);
                    if (lit.k === 'struct' && lit.f === 'true' && !lit.args.length) {
                        yield* solve(conds, idx + 1, s);
                        return;
                    }
                    for (const b of bb) {
                        const s2 = unify(c.t, b, s);
                        if (s2) yield* solve(conds, idx + 1, s2);
                    }
                    for (const r of rules) {
                        const s2 = unify(r.head, c.t, s);
                        if (!s2) continue;
                        for (const sr of solve(r.body, 0, s2)) {
                            yield* solve(conds, idx + 1, sr);
                        }
                    }
                } else if (c.k === 'cmp') {
                    const l = evalArith(c.l, s), r = evalArith(c.r, s);
                    let ok = false;
                    if (l !== null && r !== null) {
                        switch (c.op) {
                            case '>': ok = l > r; break;
                            case '<': ok = l < r; break;
                            case '>=': ok = l >= r; break;
                            case '<=': ok = l <= r; break;
                            case '==': ok = l === r; break;
                            case '\\==': ok = l !== r; break;
                            case '=': { const s2 = unify(c.l, c.r, s); if (s2) yield* solve(conds, idx + 1, s2); return; }
                        }
                    } else if (c.op === '=') {
                        const s2 = unify(c.l, c.r, s);
                        if (s2) yield* solve(conds, idx + 1, s2);
                        return;
                    } else if (c.op === '==' || c.op === '\\==') {
                        const eq = fmt(c.l, s) === fmt(c.r, s);
                        ok = c.op === '==' ? eq : !eq;
                    }
                    if (ok) yield* solve(conds, idx + 1, s);
                } else if (c.k === 'not') {
                    let found = false;
                    for (const _ of solve([c.c], 0, s)) { found = true; break; }
                    if (!found) yield* solve(conds, idx + 1, s);
                }
            }

            function ground(t, s) {
                t = walk(t, s);
                if (t.k === 'arith') { const v = evalArith(t, s); return v === null ? t : { k: 'num', v }; }
                if (t.k === 'neg') return { k: 'neg', t: ground(t.t, s) };
                if (t.k === 'list') {
                    return {
                        k: 'list',
                        items: t.items.map((a) => ground(a, s)),
                        tail: t.tail ? ground(t.tail, s) : null,
                    };
                }
                if (t.k === 'struct') return { k: 'struct', f: t.f, args: t.args.map((a) => ground(a, s)) };
                return t;
            }

            function addBelief(t, s, depth) {
                const g = ground(t, s);
                if (!bb.some((b) => unify(b, g, new Map()) && fmt(b) === fmt(g))) {
                    bb.push(g);
                    log('belief', `+ belief added: ${fmt(g)}`);
                    handleEvent({ sign: '+', goal: false, t: g }, depth + 1);
                } else {
                    log('muted', `· belief already present: ${fmt(g)}`);
                }
            }

            function delBelief(t, s, depth) {
                const q = ground(t, s);
                const i = bb.findIndex((b) => unify(q, b, new Map()));
                if (i >= 0) {
                    const removed = bb.splice(i, 1)[0];
                    log('belief', `- belief removed: ${fmt(removed)}`);
                    handleEvent({ sign: '-', goal: false, t: removed }, depth + 1);
                } else {
                    log('muted', `· no belief matches ${fmt(q)}`);
                }
            }

            function execBody(body, s, depth) {
                let cur = s;
                for (const f of body) {
                    tick();
                    if (f.k === 'achieve') {
                        const g = ground(f.t, cur);
                        log('event', `${'  '.repeat(depth)}! new goal: !${fmt(g)}`);
                        handleEvent({ sign: '+', goal: true, t: g }, depth + 1);
                    } else if (f.k === 'test') {
                        let found = null;
                        for (const s2 of solve([{ k: 'lit', t: f.t }], 0, cur)) {
                            found = s2;
                            break;
                        }
                        if (!found) {
                            log('error', `${'  '.repeat(depth)}✗ test goal failed: ?${fmt(f.t, cur)}`);
                            return false;
                        }
                        cur = found;
                        log('muted', `${'  '.repeat(depth)}· test goal succeeded: ?${fmt(f.t, cur)}`);
                    } else if (f.k === 'addB') {
                        addBelief(f.t, cur, depth);
                    } else if (f.k === 'delB') {
                        delBelief(f.t, cur, depth);
                    } else if (f.k === 'internal') {
                        if (f.name === 'print') {
                            log('print', `${'  '.repeat(depth)}» ${f.args.map((a) => fmt(a, cur)).join(' ')}`);
                        } else if (f.name === 'send') {
                            const [to, perf, ...rest] = f.args;
                            log('send', `${'  '.repeat(depth)}✉ .send → ${fmt(to, cur)} [${fmt(perf, cur)}] ${rest.map((a) => fmt(a, cur)).join(' ')}`);
                        } else if (f.name === 'wait') {
                            log('muted', `${'  '.repeat(depth)}… .wait`);
                        } else {
                            log('muted', `${'  '.repeat(depth)}· internal action .${f.name} (no-op here)`);
                        }
                    } else if (f.k === 'action') {
                        log('action', `${'  '.repeat(depth)}⚙ action executed: ${fmt(f.t, cur)}`);
                    }
                }
                return true;
            }

            function handleEvent(ev, depth) {
                if (depth > 24) throw new Error('Recursion too deep');
                const kind = `${ev.sign}${ev.goal ? '!' : ''}`;
                const candidates = plans.filter((pl) => pl.sign === ev.sign && pl.goal === ev.goal);
                for (const pl of candidates) {
                    const s0 = unify(pl.head, ev.t, new Map());
                    if (!s0) continue;
                    for (const s of solve(pl.context, 0, s0)) {
                        log('plan', `${'  '.repeat(Math.max(0, depth - 1))}▶ plan selected: ${kind}${fmt(pl.head)}${contextStr(pl)}`);
                        if (execBody(pl.body, s, depth)) return true;
                    }
                }
                if (ev.goal) log('error', `✗ no applicable plan for ${kind}${fmt(ev.t)}`);
                return false;
            }

            function contextStr(pl) {
                const c = pl.context;
                if (c.length === 1 && c[0].k === 'lit' && c[0].t.f === 'true') return '';
                return '  (context ok)';
            }

            // boot: initial beliefs, then initial goals
            log('muted', '— SPADE BDI reasoning cycle started —');
            beliefs.forEach((b) => {
                bb.push(b);
                log('belief', `+ initial belief: ${fmt(b)}`);
            });
            beliefs.forEach((b) => handleEvent({ sign: '+', goal: false, t: b }, 1));
            goals.forEach((g) => {
                log('event', `! initial goal: !${fmt(g)}`);
                handleEvent({ sign: '+', goal: true, t: g }, 1);
            });
            log('muted', `— idle: no pending events (${steps} steps) —`);
            return bb;
        }

        /* ---------- Examples ---------- */
        const EXAMPLES = {
            greeter: `// A polite agent: beliefs + parametrised plans
likes(alice, coffee).
likes(bob, tea).

!greet_all.

+!greet_all : true <-
    .print("Looking for friends...");
    !greet(alice);
    !greet(bob);
    .send(alice, tell, party(saturday)).

+!greet(Who) : likes(Who, Drink) <-
    .print("Hello", Who, "- I know you like", Drink).

+!greet(Who) : not likes(Who, _) <-
    .print("Hi", Who, "- nice to meet you!").`,

            thermostat: `// Reactive belief-triggered plans + belief updates
threshold(25).
temperature(31).

!check.

+!check : temperature(T) & threshold(M) & T > M <-
    .print("Too hot:", T, "degrees");
    turn_on_ac;
    -temperature(T);
    +temperature(24).

+!check : temperature(T) & threshold(M) & T <= M <-
    .print("Comfortable:", T, "degrees").

// React to ANY new temperature reading
+temperature(T) : threshold(M) & T <= M <-
    .print("New reading", T, "is fine. AC off");
    turn_off_ac.`,

            patrol: `// Sequential subgoals over a belief base
checkpoint(gate).
checkpoint(warehouse).
checkpoint(lab).
battery(80).

!patrol.

+!patrol : battery(B) & B > 20 <-
    .print("Patrol started. Battery:", B);
    !visit(gate);
    !visit(warehouse);
    !visit(lab);
    .print("Patrol finished");
    .send(base, tell, patrol_done).

+!patrol : battery(B) & B <= 20 <-
    .print("Battery too low:", B);
    !recharge.

+!visit(P) : checkpoint(P) <-
    move_to(P);
    .print("Checkpoint", P, "secured").

+!visit(P) : not checkpoint(P) <-
    .print("Unknown checkpoint:", P).`,

            list_walk: `// Lists with head/tail decomposition
friends([alice, bob, carol]).

!greet_all.

+!greet_all : friends(L) <-
    .print("Starting list walk");
    !walk(L).

+!walk([]) <-
    .print("Done: empty list reached").

+!walk([H|T]) <-
    .print("Hello", H);
    !walk(T).`,

            list_strings: `// Lists + strings in one program
pending([alice, bob, carol]).
prefix("[SPADE] reminder for").

!notify_pending.

+!notify_pending : pending(Users) & prefix(P) <-
    !notify_each(Users, P).

+!notify_each([], _P) <-
    .print("All reminders sent").

+!notify_each([User|Rest], P) <-
    .print(P, User);
    .send(User, tell, reminder_ready(User));
    !notify_each(Rest, P).`,

            rules: `// Rules derive facts on demand from beliefs
parent(tom, bob).
parent(bob, ann).

grandparent(X, Z) :- parent(X, Y) & parent(Y, Z).

!check_family.

+!check_family : grandparent(tom, ann) <-
    .print("Rule matched:", tom, "is grandparent of", ann).

+!check_family : not grandparent(ann, tom) <-
    .print("As expected:", ann, "is not grandparent of", tom).`,

            operators: `// Operators in context: arithmetic + comparisons
temperature(31).
threshold(25).
funds(120).
price(sensor, 45).

!evaluate.

+!evaluate : temperature(T) & threshold(M) & T > M <-
    .print("Too hot:", T, ">", M).

+!evaluate : funds(F) & price(sensor, P) & F >= P <-
    .print("Can buy sensor. Remaining:", F - P).

+!evaluate : funds(F) & price(sensor, P) & F < P <-
    .print("Not enough funds").`,

            explicit_negation: `// Explicit negation (~) as a known false fact
~raining.
umbrella(alice).

!decide.

+!decide : ~raining <-
    .print("No rain now").

+!decide : raining <-
    .print("Take an umbrella").

+!decide : not raining <-
    .print("raining is not provable").`,

            test_goal: `// Test goals (?g) query beliefs and bind variables
temperature(22).
temperature(26).
room(lab).

!report.

+!report <-
    ?room(R);
    ?temperature(T);
    .print("Measurement in", R, "=", T).

+!report : not room(storage) <-
    .print("No data for storage").`,
        };

        /* ---------- UI wiring ---------- */
        const editor = document.getElementById('asl-editor');
        const highlightEl = document.getElementById('asl-editor-highlight');
        const consoleEl = document.getElementById('asl-console');
        const beliefsEl = document.getElementById('asl-beliefs');
        const runBtn = document.getElementById('asl-run');
        const clearBtn = document.getElementById('asl-clear');
        const exampleSel = document.getElementById('asl-example');
        if (!editor || !highlightEl || !consoleEl || !runBtn) return;

        function escHtml(str) {
            return str
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;');
        }

        function tokenClass(token) {
            if (token.startsWith('//')) return 'asl-tk-comment';
            if (token.startsWith('"')) return 'asl-tk-string';
            if (token.startsWith('.')) return 'asl-tk-internal';
            if (/^[A-Z_]/.test(token)) return 'asl-tk-variable';
            if (/^-?\d/.test(token)) return 'asl-tk-number';
            if (/^(not|true)$/.test(token)) return 'asl-tk-keyword';
            return 'asl-tk-operator';
        }

        function renderHighlight(src) {
            const tokenRe = /\/\/[^\n]*|"(?:\\.|[^"\\])*"|\.[a-z][A-Za-z0-9_]*|\b(?:not|true)\b|\b[A-Z_][A-Za-z0-9_]*\b|-?\d+(?:\.\d+)?|\+!|\-!|\+\?|\-\?|<\-|:\-|\\==|==|<=|>=|[()\[\],.;:+\-!~?:&|]/g;
            let out = '';
            let last = 0;
            tokenRe.lastIndex = 0;
            for (const m of src.matchAll(tokenRe)) {
                const i = m.index;
                const token = m[0];
                out += escHtml(src.slice(last, i));
                out += `<span class="${tokenClass(token)}">${escHtml(token)}</span>`;
                last = i + token.length;
            }
            out += escHtml(src.slice(last));
            // Preserve trailing empty line in <pre> rendering.
            if (src.endsWith('\n')) out += '\n';
            highlightEl.innerHTML = out;
        }

        function syncHighlightScroll() {
            highlightEl.scrollTop = editor.scrollTop;
            highlightEl.scrollLeft = editor.scrollLeft;
        }

        function refreshHighlight() {
            renderHighlight(editor.value);
            syncHighlightScroll();
        }

        editor.value = EXAMPLES.greeter;
        refreshHighlight();

        editor.addEventListener('input', refreshHighlight);
        editor.addEventListener('scroll', syncHighlightScroll);

        exampleSel.addEventListener('change', () => {
            editor.value = EXAMPLES[exampleSel.value] || '';
            refreshHighlight();
            consoleEl.innerHTML = '';
            beliefsEl.innerHTML = '';
        });

        clearBtn.addEventListener('click', () => {
            consoleEl.innerHTML = '';
            beliefsEl.innerHTML = '';
        });

        runBtn.addEventListener('click', () => {
            consoleEl.innerHTML = '';
            beliefsEl.innerHTML = '';
            const lines = [];
            const log = (type, msg) => lines.push({ type, msg });
            let finalBB = [];
            try {
                finalBB = run(editor.value, log);
            } catch (err) {
                lines.push({ type: 'error', msg: `✗ ${err.message}` });
            }
            // animate the trace line by line
            lines.forEach((l, i) => {
                setTimeout(() => {
                    const span = document.createElement('span');
                    span.className = `asl-line asl-line-${l.type}`;
                    span.textContent = l.msg;
                    consoleEl.appendChild(span);
                    consoleEl.scrollTop = consoleEl.scrollHeight;
                }, i * 70);
            });
            setTimeout(() => {
                finalBB.forEach((b, i) => {
                    setTimeout(() => {
                        const chip = document.createElement('span');
                        chip.className = 'asl-belief-chip';
                        chip.textContent = fmt(b);
                        beliefsEl.appendChild(chip);
                    }, i * 60);
                });
            }, lines.length * 70 + 100);
        });
    })();
</script>
