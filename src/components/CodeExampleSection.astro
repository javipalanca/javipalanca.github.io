---
// Code Example Section component
import LiveCodeRunner from './LiveCodeRunner.astro';

const agentCode = `import spade
from spade.agent import Agent
from spade.behaviour import CyclicBehaviour
from spade.message import Message

class MyAgent(Agent):
    class MyBehaviour(CyclicBehaviour):
        async def run(self):
            msg = await self.receive(timeout=10)
            if msg:
                print(f"Message received: {msg.body}")
                reply = Message(to=str(msg.sender))
                reply.body = "I received your message!"
                await self.send(reply)

    async def setup(self):
        behaviour = self.MyBehaviour()
        self.add_behaviour(behaviour)

async def main():
    agent = MyAgent("agent@localhost", "password")
    await agent.start()

if __name__ == "__main__":
    spade.run(main())`;

// Minimal, faithful replay of exactly what this one agent does:
// start → receive a message → print it → send a reply. Nothing more.
const agentTrace = [
    { kind: 'cmd', text: 'spade run agent_example.py' },
    { kind: 'ok', text: 'agent@localhost started' },
    { kind: 'msg', dir: 'in', text: '"Hello SPADE!"' },
    { kind: 'print', text: 'Message received: Hello SPADE!' },
    { kind: 'msg', dir: 'out', text: '"I received your message!"' },
];

// The example defines a single agent; the scene shows it and its network mailbox.
const agentPreviewAgents = [
    { id: 'agent', label: 'agent@localhost', icon: 'cpu-fill', color: '#2f6bff' },
];
---

<section id="examples" class="py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5 fade-in-up">
            <h2 class="fw-bold">See SPADE Agents in Action</h2>
            <p class="lead text-muted">Write a few lines of Python, press Run, and watch your agent receive and reply to messages</p>
        </div>

        <div class="row mb-4">
            <div class="col-lg-10 mx-auto fade-in-up">
                <LiveCodeRunner
                    filename="agent_example.py"
                    code={agentCode}
                    agents={agentPreviewAgents}
                    trace={agentTrace}
                />
            </div>
        </div>

        <div class="row">
            <div class="col-lg-10 mx-auto text-center slide-in-right">
                <p class="text-muted mb-3">
                    A basic <strong>SPADE agent</strong> that receives messages and automatically replies — SPADE handles
                    presence, the XMPP connection and message delivery for you. The preview above replays the program's
                    real output; run it for yourself in a couple of commands.
                </p>
                <div class="d-flex gap-2 flex-wrap justify-content-center">
                    <a href="#get-started" class="btn btn-primary">
                        <i class="bi bi-rocket-takeoff me-2"></i>Get Started
                    </a>
                    <a href="/spade" class="btn btn-outline-primary">
                        <i class="bi bi-cpu me-2"></i>Explore SPADE Framework
                    </a>
                    <a href="https://spadeagents.eu/docs/spade/usage" class="btn btn-outline-primary">More Examples</a>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .code-example {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 10px;
        overflow: hidden;
    }
    
    /* Dark mode badge section and code example */
    :global(body.dark-mode) .code-example {
        background: var(--dark-card-bg) !important;
        border-color: var(--dark-border) !important;
    }
    
    .code-header {
        background: #f0f0f0;
        color: #333;
        padding: 12px 20px;
        border-bottom: 1px solid #dee2e6;
        font-weight: 600;
    }
    
    .code-body {
        padding: 20px;
        background-color: #ffffff;
    }
    
    /* Dark mode code body styles */
    :global(body.dark-mode) .code-header {
        background: #343a40;
        color: white;
        border-bottom-color: #4a5568;
    }
    :global(body.dark-mode) .code-body {
        background-color: #1a202c !important;
    }
    
    :global(body.dark-mode) .code-body pre {
        background-color: #1a202c !important;
        color: #e2e8f0 !important;
    }
    
    :global(body.dark-mode) .code-body code {
        color: #e2e8f0 !important;
    }
</style>
</section>
