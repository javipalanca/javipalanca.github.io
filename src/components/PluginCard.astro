---
// Plugin component for the plugins section
export interface Plugin {
  name: string;
  description: string;
  icon: string;
  githubUrl: string;
  docsUrl: string;
  pluginUrl: string;
  featured?: boolean;
}

interface Props {
  plugin: Plugin;
}

const { plugin } = Astro.props;
---

<div class={`card h-100 border-0 shadow-sm ${plugin.featured ? 'featured-plugin' : ''}`}>
    <div class="card-body">
        {plugin.featured && (
            <div class="featured-badge">
                <i class="bi bi-star-fill me-1"></i>
                Featured
            </div>
        )}
        <h5 class={`card-title ${plugin.featured ? 'featured-title' : ''}`}>
            {plugin.name}
        </h5>
        <p class="card-text">{plugin.description}</p>
        <div class="plugin-actions">
            <a href={plugin.pluginUrl} class={`btn btn-sm ${plugin.featured ? 'btn-llm' : 'btn-primary'}`}>
                <i class="bi bi-info-circle me-1"></i>Learn More
            </a>
            <a href={plugin.githubUrl} class={`btn btn-sm ${plugin.featured ? 'btn-outline-purple' : 'btn-outline-primary'}`}>
                <i class="bi bi-github me-1"></i>GitHub
            </a>
        </div>
    </div>
</div>

<style>
    .featured-plugin {
        background: linear-gradient(160deg, #faf8ff, #f1ecfe);
        border: 1px solid rgba(139, 92, 246, 0.4) !important;
        position: relative;
        overflow: hidden;
        box-shadow: 0 12px 36px -10px rgba(139, 92, 246, 0.35) !important;
    }

    .featured-plugin::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, #8b5cf6, #d946ef, #8b5cf6);
        background-size: 200% 100%;
        animation: featuredSlide 3s linear infinite;
        z-index: 1;
    }

    @keyframes featuredSlide {
        to { background-position: 200% 0; }
    }

    .featured-plugin:hover {
        box-shadow: 0 24px 60px -12px rgba(139, 92, 246, 0.5) !important;
        border-color: rgba(139, 92, 246, 0.7) !important;
    }

    .featured-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        background: linear-gradient(135deg, #8b5cf6, #d946ef);
        color: white;
        padding: 0.3rem 0.8rem;
        border-radius: 50rem;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        z-index: 2;
        box-shadow: 0 6px 16px -4px rgba(139, 92, 246, 0.5);
        animation: floatY 4s ease-in-out infinite;
    }

    .featured-title {
        background: linear-gradient(135deg, #7c3aed, #d946ef);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        font-weight: 700;
    }

    .plugin-actions {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .btn-llm {
        background: linear-gradient(135deg, #8b5cf6, #d946ef);
        background-size: 160% auto;
        color: white;
        border: none;
        border-radius: 50rem;
        padding: 8px 20px;
        transition: all 0.35s var(--ease-spring, ease);
    }

    .btn-llm:hover {
        background-position: right center;
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 10px 24px -8px rgba(139, 92, 246, 0.6);
    }

    .btn-outline-purple {
        border: 2px solid #8b5cf6;
        color: #8b5cf6;
        border-radius: 50rem;
        padding: 7px 18px;
        transition: all 0.35s var(--ease-spring, ease);
    }

    .btn-outline-purple:hover {
        background: #8b5cf6;
        border-color: #8b5cf6;
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 10px 24px -8px rgba(139, 92, 246, 0.5);
    }

    /* Dark mode adjustments */
    :global(body.dark-mode) .featured-plugin {
        background: linear-gradient(160deg, #151028, #1c1438);
        border-color: rgba(167, 139, 250, 0.45) !important;
    }

    :global(body.dark-mode) .featured-title {
        background: linear-gradient(135deg, #a78bfa, #e879f9);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    :global(body.dark-mode) .btn-outline-purple {
        border-color: #a78bfa;
        color: #a78bfa;
    }
</style>
