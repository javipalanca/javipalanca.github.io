---
// Interactive Agent Demo.
// A self-contained, JSON-driven visualizer: agents are themed HTML cards,
// while a canvas underneath draws the links and animates messages flowing
// between them. Every scenario, agent type and message type is configured
// in /public/json/demos.json — edit the JSON to change the demos.
const baseUrl = import.meta.env.BASE_URL;
---

<section id="interactive-demo" class="idemo py-5">
    <div class="container">
        <div class="text-center mb-5 fade-in-up">
            <h2 class="fw-bold">Interactive Agent Demo</h2>
            <p class="lead text-muted">Pick a scenario and press play — watch SPADE agents exchange messages in real time</p>
        </div>

        <div class="idemo-shell">
            <!-- Scenario chips + transport controls -->
            <div class="idemo-toolbar">
                <div class="idemo-scenarios" id="idemo-scenarios" role="tablist" aria-label="Demo scenario"></div>
                <div class="idemo-controls">
                    <button class="idemo-btn idemo-btn-play" id="idemo-play" type="button" aria-label="Play or pause">
                        <i class="bi bi-play-fill"></i><span>Play</span>
                    </button>
                    <button class="idemo-btn" id="idemo-step" type="button" aria-label="Step one message">
                        <i class="bi bi-skip-end-fill"></i><span>Step</span>
                    </button>
                    <button class="idemo-btn" id="idemo-reset" type="button" aria-label="Reset">
                        <i class="bi bi-arrow-counterclockwise"></i>
                    </button>
                    <div class="idemo-speed" role="group" aria-label="Speed">
                        <button class="idemo-speed-btn" data-speed="0.5" type="button">0.5×</button>
                        <button class="idemo-speed-btn active" data-speed="1" type="button">1×</button>
                        <button class="idemo-speed-btn" data-speed="2" type="button">2×</button>
                    </div>
                </div>
            </div>

            <div class="idemo-main">
                <!-- Stage: canvas (links + messages) behind HTML agent cards -->
                <div class="idemo-stage" id="idemo-stage">
                    <canvas class="idemo-canvas" id="idemo-canvas" aria-hidden="true"></canvas>
                    <div class="idemo-nodes" id="idemo-nodes"></div>
                    <div class="idemo-legend" id="idemo-legend" aria-hidden="true"></div>
                </div>

                <!-- Side panel: description, concepts, live event log -->
                <aside class="idemo-side">
                    <div class="idemo-desc">
                        <h3 id="idemo-title">—</h3>
                        <p id="idemo-description">—</p>
                        <ul class="idemo-concepts" id="idemo-concepts"></ul>
                    </div>
                    <div class="idemo-log-head">
                        <i class="bi bi-terminal me-2"></i>Event log
                    </div>
                    <div class="idemo-log" id="idemo-log" aria-live="polite"></div>
                </aside>
            </div>

            <!-- Python implementation of the selected scenario -->
            <div class="idemo-code">
                <div class="idemo-code-bar">
                    <span class="idemo-code-dots"></span>
                    <span class="idemo-code-file" id="idemo-code-file">scenario.py</span>
                    <button class="idemo-copy" id="idemo-copy" type="button" title="Copy code">
                        <i class="bi bi-clipboard"></i>
                    </button>
                </div>
                <pre class="idemo-code-pre"><code class="language-python" id="idemo-code">…</code></pre>
            </div>
        </div>
    </div>
</section>

<style is:global>
    /* Styles are global because agent nodes, chips and the event log are
       created dynamically in JS — Astro's scoped styles only apply to
       elements present in the template. All classes are prefixed .idemo-. */
    .idemo-shell {
        border-radius: 22px;
        overflow: hidden;
        border: 1px solid rgba(122, 167, 255, 0.18);
        background: #0a101f;
        box-shadow: 0 30px 80px -30px rgba(7, 11, 22, 0.7);
    }

    /* ---- Toolbar ---- */
    .idemo-toolbar {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        align-items: center;
        justify-content: space-between;
        padding: 0.85rem 1rem;
        background: #0e1526;
        border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    }

    .idemo-scenarios {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }

    .idemo-chip {
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(255, 255, 255, 0.04);
        color: #93a1b8;
        font-size: 0.82rem;
        font-weight: 600;
        padding: 0.4rem 0.85rem;
        border-radius: 50rem;
        cursor: pointer;
        transition: all 0.25s var(--ease-spring, ease);
        white-space: nowrap;
    }

    .idemo-chip:hover {
        color: #e6ecf7;
        border-color: rgba(122, 167, 255, 0.4);
    }

    .idemo-chip.active {
        background: linear-gradient(135deg, #2f6bff, #06b6d4);
        border-color: transparent;
        color: #fff;
        box-shadow: 0 8px 20px -8px rgba(47, 107, 255, 0.6);
    }

    .idemo-controls {
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .idemo-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        border: 1px solid rgba(255, 255, 255, 0.14);
        background: rgba(255, 255, 255, 0.05);
        color: #d7e2f5;
        font-size: 0.82rem;
        font-weight: 600;
        padding: 0.4rem 0.8rem;
        border-radius: 50rem;
        cursor: pointer;
        transition: all 0.25s ease;
    }

    .idemo-btn:hover { background: rgba(255, 255, 255, 0.1); }

    .idemo-btn-play {
        background: linear-gradient(135deg, #10b981, #06b6d4);
        border-color: transparent;
        color: #fff;
    }

    .idemo-btn-play.playing {
        background: linear-gradient(135deg, #f59e0b, #ef4444);
    }

    .idemo-speed {
        display: flex;
        gap: 0.15rem;
        margin-left: 0.3rem;
        background: rgba(255, 255, 255, 0.05);
        padding: 0.15rem;
        border-radius: 50rem;
    }

    .idemo-speed-btn {
        border: none;
        background: transparent;
        color: #93a1b8;
        font-size: 0.74rem;
        font-weight: 700;
        padding: 0.25rem 0.55rem;
        border-radius: 50rem;
        cursor: pointer;
    }

    .idemo-speed-btn.active { background: rgba(122, 167, 255, 0.25); color: #fff; }

    /* ---- Main grid ---- */
    .idemo-main {
        display: grid;
        grid-template-columns: 1fr 300px;
        min-height: 440px;
    }

    @media (max-width: 860px) {
        .idemo-main { grid-template-columns: 1fr; }
    }

    /* ---- Stage ---- */
    .idemo-stage {
        position: relative;
        min-height: 440px;
        background:
            radial-gradient(ellipse 80% 80% at 50% 40%, rgba(47, 107, 255, 0.1), transparent 70%),
            #070c1c;
        overflow: hidden;
    }

    .idemo-canvas {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
    }

    .idemo-nodes { position: absolute; inset: 0; }

    .idemo-node {
        position: absolute;
        transform: translate(-50%, -50%);
        width: 132px;
        padding: 0.7rem 0.6rem 0.6rem;
        border-radius: 14px;
        background: rgba(14, 21, 38, 0.92);
        border: 1px solid var(--c, #2f6bff);
        box-shadow: 0 10px 26px -10px rgba(0, 0, 0, 0.7);
        text-align: center;
        transition: box-shadow 0.3s ease, transform 0.3s var(--ease-spring, ease);
        z-index: 2;
        backdrop-filter: blur(4px);
    }

    .idemo-node.pulse {
        animation: idemoPulse 0.7s var(--ease-spring, ease);
    }

    @keyframes idemoPulse {
        0% { box-shadow: 0 0 0 0 var(--c, #2f6bff), 0 10px 26px -10px rgba(0, 0, 0, 0.7); }
        40% { box-shadow: 0 0 0 7px color-mix(in srgb, var(--c, #2f6bff) 35%, transparent), 0 10px 26px -10px rgba(0, 0, 0, 0.7); transform: translate(-50%, -50%) scale(1.06); }
        100% { box-shadow: 0 0 0 0 transparent, 0 10px 26px -10px rgba(0, 0, 0, 0.7); }
    }

    .idemo-node.sending .idemo-node-icon { animation: idemoNudge 0.5s ease; }
    @keyframes idemoNudge { 50% { transform: scale(1.18); } }

    .idemo-node-icon {
        width: 42px;
        height: 42px;
        margin: 0 auto 0.4rem;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        color: #fff;
        background: var(--c, #2f6bff);
        box-shadow: 0 6px 16px -6px var(--c, #2f6bff);
    }

    .idemo-node-name {
        display: block;
        font-family: var(--font-display, sans-serif);
        font-weight: 600;
        font-size: 0.84rem;
        color: #fff;
        line-height: 1.2;
    }

    .idemo-node-jid {
        display: block;
        font-family: var(--font-mono, monospace);
        font-size: 0.62rem;
        color: #64748b;
        margin-top: 1px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .idemo-node-beh {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        margin-top: 0.4rem;
        font-size: 0.62rem;
        font-weight: 600;
        color: var(--c, #2f6bff);
        background: color-mix(in srgb, var(--c, #2f6bff) 14%, transparent);
        padding: 0.12rem 0.5rem;
        border-radius: 50rem;
    }

    .idemo-legend {
        position: absolute;
        left: 0.75rem;
        bottom: 0.6rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        max-width: 70%;
    }

    .idemo-legend span {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        font-size: 0.66rem;
        color: #93a1b8;
        font-weight: 600;
    }

    .idemo-legend i {
        width: 9px; height: 9px; border-radius: 50%;
    }

    /* ---- Side panel ---- */
    .idemo-side {
        display: flex;
        flex-direction: column;
        background: #0b1322;
        border-left: 1px solid rgba(255, 255, 255, 0.07);
    }

    @media (max-width: 860px) {
        .idemo-side { border-left: none; border-top: 1px solid rgba(255, 255, 255, 0.07); }
    }

    .idemo-desc {
        padding: 1.1rem 1.2rem 0.8rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .idemo-desc h3 {
        font-size: 1.05rem;
        color: #fff;
        margin-bottom: 0.4rem;
    }

    .idemo-desc p {
        font-size: 0.86rem;
        color: #93a1b8;
        line-height: 1.55;
        margin-bottom: 0.6rem;
    }

    .idemo-concepts {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

    .idemo-concepts li {
        position: relative;
        padding-left: 1.1rem;
        font-size: 0.78rem;
        color: #cbd5e1;
        line-height: 1.45;
    }

    .idemo-concepts li::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0.45em;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: linear-gradient(135deg, #2f6bff, #10b981);
    }

    .idemo-log-head {
        padding: 0.6rem 1.2rem;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #64748b;
    }

    .idemo-log {
        flex: 1;
        overflow-y: auto;
        padding: 0 1.2rem 1rem;
        font-family: var(--font-mono, monospace);
        font-size: 0.74rem;
        line-height: 1.7;
        max-height: 220px;
    }

    .idemo-log:empty::before {
        content: "Press play to start…";
        color: #475569;
    }

    .idemo-log-line {
        display: block;
        animation: idemoLogIn 0.25s ease both;
        color: #cbd5e1;
    }

    .idemo-log-line .arrow { color: #64748b; }
    .idemo-log-line .perf { font-weight: 700; }

    @keyframes idemoLogIn {
        from { opacity: 0; transform: translateX(-6px); }
        to { opacity: 1; transform: translateX(0); }
    }

    /* ---- Code ---- */
    .idemo-code {
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        background: #070c1c;
    }

    .idemo-code-bar {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.55rem 1rem;
        background: #0e1526;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .idemo-code-dots {
        width: 11px; height: 11px; border-radius: 50%;
        background: #ff5f57;
        box-shadow: 18px 0 0 #febc2e, 36px 0 0 #28c840;
        margin-right: 38px;
    }

    .idemo-code-file {
        font-family: var(--font-mono, monospace);
        font-size: 0.8rem;
        color: #93a1b8;
        flex: 1;
    }

    .idemo-copy {
        border: 1px solid rgba(255, 255, 255, 0.15);
        background: transparent;
        color: #93a1b8;
        border-radius: 8px;
        padding: 0.2rem 0.5rem;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .idemo-copy:hover { color: #fff; border-color: rgba(255, 255, 255, 0.3); }
    .idemo-copy.copied { color: #34d399; border-color: #34d399; }

    .idemo-code-pre {
        margin: 0;
        max-height: 340px;
        overflow: auto;
        padding: 1rem 1.2rem;
    }

    /* Force the dark code palette regardless of the site theme. Prism adds a
       `language-*` class to the <pre>, so the global `pre[class*="language-"]`
       rule would otherwise win — use a more specific selector to override it. */
    .idemo-code pre.idemo-code-pre,
    .idemo-code pre.idemo-code-pre code {
        background: transparent !important;
        border: none !important;
        color: #d7e2f5 !important;
        font-family: var(--font-mono, monospace);
        font-size: 0.8rem;
        line-height: 1.65;
    }

    /* Bright token palette pinned for the always-dark code pane */
    .idemo-code pre.idemo-code-pre .token.comment,
    .idemo-code pre.idemo-code-pre .token.prolog,
    .idemo-code pre.idemo-code-pre .token.doctype,
    .idemo-code pre.idemo-code-pre .token.cdata { color: #64748b !important; font-style: italic; }
    .idemo-code pre.idemo-code-pre .token.punctuation { color: #9aa7bd !important; }
    .idemo-code pre.idemo-code-pre .token.keyword,
    .idemo-code pre.idemo-code-pre .token.atrule,
    .idemo-code pre.idemo-code-pre .token.attr-value { color: #c084fc !important; }
    .idemo-code pre.idemo-code-pre .token.boolean,
    .idemo-code pre.idemo-code-pre .token.number,
    .idemo-code pre.idemo-code-pre .token.constant,
    .idemo-code pre.idemo-code-pre .token.tag,
    .idemo-code pre.idemo-code-pre .token.property,
    .idemo-code pre.idemo-code-pre .token.symbol,
    .idemo-code pre.idemo-code-pre .token.deleted { color: #fbbf24 !important; }
    .idemo-code pre.idemo-code-pre .token.string,
    .idemo-code pre.idemo-code-pre .token.char,
    .idemo-code pre.idemo-code-pre .token.attr-name,
    .idemo-code pre.idemo-code-pre .token.builtin,
    .idemo-code pre.idemo-code-pre .token.inserted,
    .idemo-code pre.idemo-code-pre .token.selector { color: #34d399 !important; }
    .idemo-code pre.idemo-code-pre .token.operator,
    .idemo-code pre.idemo-code-pre .token.entity,
    .idemo-code pre.idemo-code-pre .token.url { color: #60a5fa !important; }
    .idemo-code pre.idemo-code-pre .token.function,
    .idemo-code pre.idemo-code-pre .token.class-name { color: #f472b6 !important; }
    .idemo-code pre.idemo-code-pre .token.variable,
    .idemo-code pre.idemo-code-pre .token.regex,
    .idemo-code pre.idemo-code-pre .token.important { color: #fde047 !important; }

    @media (prefers-reduced-motion: reduce) {
        .idemo-node.pulse, .idemo-node.sending .idemo-node-icon { animation: none; }
    }
</style>

<script is:inline define:vars={{ baseUrl }}>
    (() => {
        const stage = document.getElementById('idemo-stage');
        if (!stage) return;

        const canvas = document.getElementById('idemo-canvas');
        const ctx = canvas.getContext('2d');
        const nodesEl = document.getElementById('idemo-nodes');
        const legendEl = document.getElementById('idemo-legend');
        const scenariosEl = document.getElementById('idemo-scenarios');
        const logEl = document.getElementById('idemo-log');
        const titleEl = document.getElementById('idemo-title');
        const descEl = document.getElementById('idemo-description');
        const conceptsEl = document.getElementById('idemo-concepts');
        const codeEl = document.getElementById('idemo-code');
        const codeFileEl = document.getElementById('idemo-code-file');
        const playBtn = document.getElementById('idemo-play');
        const stepBtn = document.getElementById('idemo-step');
        const resetBtn = document.getElementById('idemo-reset');
        const copyBtn = document.getElementById('idemo-copy');
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        const behIcon = {
            cyclic: 'arrow-repeat', 'one-shot': '1-circle', periodic: 'clock',
            presenceNotification: 'eye', publication: 'broadcast', subscription: 'rss',
            autoResponse: 'reply', messageForwarding: 'arrow-right', messageAggregation: 'collection',
        };

        let data = null, demo = null, types = {}, edgeTypes = {};
        let layout = [];           // {id, node, el, nx, ny}
        let sequence = [];         // ordered message events
        let seqIndex = 0;
        let playing = false;
        let speed = 1;
        let packet = null;         // current animated message
        let rafId = 0;
        let W = 0, H = 0, DPR = 1;

        /* ---------- data ---------- */
        async function boot() {
            try {
                if (window.demoData) data = window.demoData;
                else data = await (await fetch(`${baseUrl}json/demos.json`)).json();
            } catch (e) { return; }
            types = data.agentTypes || {};
            edgeTypes = data.edgeTypes || {};
            renderScenarioChips();
            buildLegend();
            selectDemo(data.demos[0].id);
            window.addEventListener('resize', () => { if (demo) { positionNodes(); resize(); drawStatic(); } }, { passive: true });
        }

        function renderScenarioChips() {
            scenariosEl.innerHTML = '';
            data.demos.forEach((d) => {
                const b = document.createElement('button');
                b.className = 'idemo-chip';
                b.type = 'button';
                b.textContent = d.name;
                b.dataset.id = d.id;
                b.addEventListener('click', () => selectDemo(d.id));
                scenariosEl.appendChild(b);
            });
        }

        function buildLegend() {
            const seen = new Set();
            legendEl.innerHTML = '';
            // built per-demo in selectDemo
        }

        /* ---------- scenario selection ---------- */
        function selectDemo(id) {
            demo = data.demos.find((d) => d.id === id);
            if (!demo) return;
            stop();
            seqIndex = 0;
            packet = null;
            logEl.innerHTML = '';

            scenariosEl.querySelectorAll('.idemo-chip').forEach((c) =>
                c.classList.toggle('active', c.dataset.id === id));

            titleEl.textContent = demo.name;
            descEl.textContent = demo.description;
            conceptsEl.innerHTML = (demo.concepts || []).map((c) => `<li>${c}</li>`).join('');
            codeFileEl.textContent = demo.pythonFile || 'scenario.py';

            buildLayout();
            buildSequence();
            buildDemoLegend();
            loadCode();
            resize();
            drawStatic();
        }

        function buildDemoLegend() {
            const seen = new Map();
            demo.edges.forEach((e) => {
                const t = edgeTypes[e.type] || { color: '#2f6bff', label: e.type };
                if (!seen.has(e.type)) seen.set(e.type, t);
            });
            legendEl.innerHTML = [...seen.values()]
                .map((t) => `<span><i style="background:${t.color}"></i>${t.label}</span>`)
                .join('');
        }

        /* ---------- layout ---------- */
        function buildLayout() {
            nodesEl.innerHTML = '';
            const xs = demo.nodes.map((n) => n.position.x);
            const ys = demo.nodes.map((n) => n.position.y);
            const minX = Math.min(...xs), maxX = Math.max(...xs);
            const minY = Math.min(...ys), maxY = Math.max(...ys);
            const spanX = maxX - minX || 1, spanY = maxY - minY || 1;

            layout = demo.nodes.map((n) => {
                const t = types[n.type] || { color: '#2f6bff', icon: 'cpu', label: n.type };
                const nx = 0.12 + ((n.position.x - minX) / spanX) * 0.76;
                const ny = 0.16 + ((n.position.y - minY) / spanY) * 0.68;
                const beh = (n.behaviors && n.behaviors[0]) || null;

                const el = document.createElement('div');
                el.className = 'idemo-node';
                el.style.setProperty('--c', t.color);
                el.style.left = (nx * 100) + '%';
                el.style.top = (ny * 100) + '%';
                el.dataset.id = n.id;
                el.innerHTML = `
                    <span class="idemo-node-icon"><i class="bi bi-${t.icon}"></i></span>
                    <span class="idemo-node-name">${t.label}</span>
                    <span class="idemo-node-jid">${n.id}@localhost</span>
                    ${beh ? `<span class="idemo-node-beh"><i class="bi bi-${behIcon[beh.type] || 'lightning-charge'}"></i>${beh.name}</span>` : ''}
                `;
                nodesEl.appendChild(el);
                return { id: n.id, node: n, el, nx, ny };
            });
            positionNodes();
        }

        function positionNodes() {
            // % positioning is handled by CSS left/top; nothing to recompute,
            // but keep hook for future pixel-snapping.
        }

        function nodeCenter(id) {
            const L = layout.find((l) => l.id === id);
            return L ? { x: L.nx * W, y: L.ny * H } : { x: 0, y: 0 };
        }

        /* ---------- sequence ---------- */
        function buildSequence() {
            sequence = demo.edges.map((e) => {
                const t = edgeTypes[e.type] || { color: '#2f6bff', label: e.type };
                return { from: e.from, to: e.to, color: t.color, perf: t.label, label: e.label || '' };
            });
        }

        /* ---------- canvas ---------- */
        function resize() {
            DPR = Math.min(window.devicePixelRatio || 1, 2);
            W = stage.clientWidth;
            H = stage.clientHeight;
            canvas.width = Math.round(W * DPR);
            canvas.height = Math.round(H * DPR);
            ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
        }

        function edgePath(a, b) {
            // gentle curve for visual interest
            const mx = (a.x + b.x) / 2, my = (a.y + b.y) / 2;
            const dx = b.x - a.x, dy = b.y - a.y;
            const len = Math.hypot(dx, dy) || 1;
            const nx = -dy / len, ny = dx / len;
            const bow = Math.min(40, len * 0.12);
            return { cx: mx + nx * bow, cy: my + ny * bow };
        }

        function pointOnCurve(a, c, b, t) {
            const u = 1 - t;
            return {
                x: u * u * a.x + 2 * u * t * c.x + t * t * b.x,
                y: u * u * a.y + 2 * u * t * c.y + t * t * b.y,
            };
        }

        function drawStatic() {
            ctx.clearRect(0, 0, W, H);
            demo.edges.forEach((e) => {
                const a = nodeCenter(e.from), b = nodeCenter(e.to);
                const c = edgePath(a, b);
                ctx.strokeStyle = 'rgba(122,167,255,0.16)';
                ctx.lineWidth = 1.5;
                ctx.setLineDash([4, 5]);
                ctx.beginPath();
                ctx.moveTo(a.x, a.y);
                ctx.quadraticCurveTo(c.cx, c.cy, b.x, b.y);
                ctx.stroke();
                ctx.setLineDash([]);
            });
        }

        /* ---------- animation ---------- */
        function fireMessage(onDone) {
            const ev = sequence[seqIndex % sequence.length];
            const a = nodeCenter(ev.from), b = nodeCenter(ev.to);
            const c = edgePath(a, b);
            packet = { ev, a, b, c, t: 0, done: onDone };
            const fromEl = layout.find((l) => l.id === ev.from)?.el;
            if (fromEl) { fromEl.classList.add('sending'); setTimeout(() => fromEl.classList.remove('sending'), 500); }
            if (!rafId) rafId = requestAnimationFrame(frame);
        }

        function logEvent(ev) {
            const from = types[layout.find((l) => l.id === ev.from)?.node.type]?.label || ev.from;
            const to = types[layout.find((l) => l.id === ev.to)?.node.type]?.label || ev.to;
            const line = document.createElement('span');
            line.className = 'idemo-log-line';
            line.innerHTML = `<span class="perf" style="color:${ev.color}">${ev.perf}</span> ` +
                `${ev.from} <span class="arrow">→</span> ${ev.to}` +
                (ev.label ? ` <span class="arrow">·</span> ${ev.label.replace(/^[^·]*·\s*/, '')}` : '');
            logEl.appendChild(line);
            logEl.scrollTop = logEl.scrollHeight;
            while (logEl.children.length > 30) logEl.removeChild(logEl.firstChild);
        }

        function frame() {
            rafId = 0;
            ctx.clearRect(0, 0, W, H);
            drawStatic();

            if (packet) {
                packet.t += 0.018 * speed;
                const { a, b, c, ev } = packet;

                // highlight the active edge
                ctx.strokeStyle = ev.color + '88';
                ctx.lineWidth = 2.5;
                ctx.beginPath();
                ctx.moveTo(a.x, a.y);
                ctx.quadraticCurveTo(c.cx, c.cy, b.x, b.y);
                ctx.stroke();

                // travelling packet with trail
                for (let i = 0; i < 6; i++) {
                    const tt = Math.max(0, packet.t - i * 0.05);
                    const p = pointOnCurve(a, { x: c.cx, y: c.cy }, b, Math.min(tt, 1));
                    const r = (7 - i) * (1 - i * 0.04);
                    ctx.globalAlpha = (1 - i / 6) * 0.9;
                    ctx.fillStyle = ev.color;
                    ctx.beginPath();
                    ctx.arc(p.x, p.y, Math.max(1, r), 0, Math.PI * 2);
                    ctx.fill();
                }
                ctx.globalAlpha = 1;

                // moving label
                const lp = pointOnCurve(a, { x: c.cx, y: c.cy }, b, Math.min(packet.t, 1));
                const text = ev.perf;
                ctx.font = '600 11px ui-monospace, monospace';
                const tw = ctx.measureText(text).width;
                ctx.fillStyle = 'rgba(7,12,28,0.85)';
                roundRect(lp.x - tw / 2 - 7, lp.y - 22, tw + 14, 16, 8);
                ctx.fill();
                ctx.fillStyle = ev.color;
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.fillText(text, lp.x, lp.y - 14);

                if (packet.t >= 1) {
                    const toEl = layout.find((l) => l.id === ev.to)?.el;
                    if (toEl) { toEl.classList.add('pulse'); setTimeout(() => toEl.classList.remove('pulse'), 700); }
                    logEvent(ev);
                    const done = packet.done;
                    packet = null;
                    drawStatic();
                    if (done) done();
                    return;
                }
                rafId = requestAnimationFrame(frame);
            }
        }

        function roundRect(x, y, w, h, r) {
            ctx.beginPath();
            ctx.moveTo(x + r, y);
            ctx.arcTo(x + w, y, x + w, y + h, r);
            ctx.arcTo(x + w, y + h, x, y + h, r);
            ctx.arcTo(x, y + h, x, y, r);
            ctx.arcTo(x, y, x + w, y, r);
            ctx.closePath();
        }

        /* ---------- transport ---------- */
        function playLoop() {
            if (!playing) return;
            fireMessage(() => {
                seqIndex++;
                if (!playing) return;
                const gap = seqIndex % sequence.length === 0 ? 900 : 450;
                setTimeout(playLoop, gap / speed);
            });
        }

        function play() {
            if (playing) return;
            playing = true;
            playBtn.classList.add('playing');
            playBtn.innerHTML = '<i class="bi bi-pause-fill"></i><span>Pause</span>';
            playLoop();
        }

        function stop() {
            playing = false;
            playBtn.classList.remove('playing');
            playBtn.innerHTML = '<i class="bi bi-play-fill"></i><span>Play</span>';
            if (rafId) { cancelAnimationFrame(rafId); rafId = 0; }
        }

        function step() {
            stop();
            if (!packet) fireMessage(() => { seqIndex++; });
        }

        function reset() {
            stop();
            seqIndex = 0;
            packet = null;
            logEl.innerHTML = '';
            drawStatic();
        }

        /* ---------- code ---------- */
        async function loadCode() {
            try {
                const txt = await (await fetch(`${baseUrl}py/${demo.pythonFile}`)).text();
                codeEl.textContent = txt;
                codeEl.className = 'language-python';
                if (window.Prism) window.Prism.highlightElement(codeEl);
            } catch (e) {
                codeEl.textContent = '# Source not available';
            }
        }

        /* ---------- wire up ---------- */
        playBtn.addEventListener('click', () => (playing ? stop() : play()));
        stepBtn.addEventListener('click', step);
        resetBtn.addEventListener('click', reset);
        document.querySelectorAll('.idemo-speed-btn').forEach((b) => {
            b.addEventListener('click', () => {
                speed = parseFloat(b.dataset.speed);
                document.querySelectorAll('.idemo-speed-btn').forEach((x) => x.classList.toggle('active', x === b));
            });
        });
        copyBtn.addEventListener('click', async () => {
            try {
                await navigator.clipboard.writeText(codeEl.textContent);
                copyBtn.classList.add('copied');
                copyBtn.innerHTML = '<i class="bi bi-check-lg"></i>';
                setTimeout(() => { copyBtn.classList.remove('copied'); copyBtn.innerHTML = '<i class="bi bi-clipboard"></i>'; }, 1600);
            } catch (e) {}
        });

        // Pause when offscreen
        const io = new IntersectionObserver((entries) => {
            entries.forEach((e) => { if (!e.isIntersecting && playing) stop(); });
        }, { threshold: 0 });
        io.observe(stage);

        boot();
    })();
</script>
