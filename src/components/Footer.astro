---
// Footer component
const baseUrl = import.meta.env.BASE_URL;
---

<footer class="footer py-5">
    <div class="container">
        <div class="row">
            <div class="col-lg-4 mb-4">
                <div class="d-flex align-items-center mb-3">
                    <img src={`${baseUrl}img/spadelogo_new.png`} alt="SPADE Logo" height="40">
                </div>
                <p class="text-muted">Smart Python Agent Development Environment - Building the future of multi-agent systems.</p>
                <div class="d-flex gap-3">
                    <a href="https://github.com/javipalanca/spade" class="text-white"><i class="bi bi-github fs-4"></i></a>
                    <a href="https://spadeagents.eu/docs/spade" class="text-white"><i class="bi bi-book fs-4"></i></a>
                    <a href="https://pypi.org/project/spade/" class="text-white"><i class="bi bi-box fs-4"></i></a>
                </div>
            </div>
            <div class="col-lg-2 col-md-6 mb-4">
                <h6 class="text-uppercase fw-bold">Documentation</h6>
                <ul class="list-unstyled">
                    <li><a href="https://spadeagents.eu/docs/spade/installation" class="text-muted text-decoration-none">Installation</a></li>
                    <li><a href="https://spadeagents.eu/docs/spade/usage" class="text-muted text-decoration-none">User Guide</a></li>
                    <li><a href="https://spadeagents.eu/docs/spade/api" class="text-muted text-decoration-none">API Reference</a></li>
                    <li><a href="https://spadeagents.eu/docs/spade/examples" class="text-muted text-decoration-none">Examples</a></li>
                    <li><a href="/agentspeak" class="text-muted text-decoration-none">AgentSpeak Lab</a></li>
                </ul>
            </div>
            <div class="col-lg-2 col-md-6 mb-4">
                <h6 class="text-uppercase fw-bold">Plugins</h6>
                <ul class="list-unstyled">
                    <li><a href="https://github.com/javipalanca/spade_bdi" class="text-muted text-decoration-none">SPADE BDI</a></li>
                    <li><a href="https://github.com/javipalanca/spade_pubsub" class="text-muted text-decoration-none">SPADE PubSub</a></li>
                    <li><a href="https://github.com/javipalanca/spade_artifact" class="text-muted text-decoration-none">SPADE Artifact</a></li>
                    <li><a href="https://github.com/javipalanca/spade_norms" class="text-muted text-decoration-none">SPADE Norms</a></li>
                </ul>
            </div>
            <div class="col-lg-2 col-md-6 mb-4">
                <h6 class="text-uppercase fw-bold">Community</h6>
                <ul class="list-unstyled">
                    <li><a href="https://github.com/javipalanca/spade" class="text-muted text-decoration-none">GitHub</a></li>
                    <li><a href="https://github.com/javipalanca/spade/issues" class="text-muted text-decoration-none">Issue Tracker</a></li>
                    <li><a href="https://github.com/javipalanca/spade/discussions" class="text-muted text-decoration-none">Discussions</a></li>
                    <li><a href="https://github.com/javipalanca/spade/wiki" class="text-muted text-decoration-none">Wiki</a></li>
                </ul>
            </div>
            <div class="col-lg-2 col-md-6 mb-4">
                <h6 class="text-uppercase fw-bold">Legal</h6>
                <ul class="list-unstyled">
                    <li><a href="https://github.com/javipalanca/spade/blob/master/LICENSE" class="text-muted text-decoration-none">MIT License</a></li>
                    <li><a href="#" class="text-muted text-decoration-none">Privacy Policy</a></li>
                </ul>
            </div>
        </div>
        <hr class="my-4">
        <div class="row align-items-center">
            <div class="col-md-6">
                <p class="mb-0 text-muted">&copy; 2025 SPADE Team. Licensed under MIT License.</p>
                <p class="mb-0 text-muted">Funded by <a href="https://vrain.upv.es/" class="text-decoration-none" target="_blank">VRAIN - Valencian Research Institute for Artificial Intelligence</a></p>
            </div>
            <div class="col-md-6 text-md-end">
                <p class="mb-0 text-muted">Made with ❤️ for the multi-agent systems community</p>
            </div>
        </div>
    </div>
</footer>

<style>
    .footer {
        position: relative;
        background:
            radial-gradient(ellipse 70% 120% at 20% 0%, rgba(47, 107, 255, 0.14), transparent 60%),
            radial-gradient(ellipse 60% 120% at 85% 100%, rgba(139, 92, 246, 0.12), transparent 60%),
            #0b1228;
        color: #e6ecf7;
        overflow: hidden;
    }

    .footer::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, #2f6bff, #06b6d4, #10b981, #8b5cf6);
        background-size: 200% 100%;
        animation: footerGlow 6s linear infinite;
    }

    @keyframes footerGlow {
        to { background-position: 200% 0; }
    }

    .footer h6 {
        color: #fff;
        letter-spacing: 0.12em;
        font-size: 0.8rem;
        margin-bottom: 1rem;
    }

    .footer .text-muted,
    .footer a.text-muted {
        color: #93a1b8 !important;
    }

    .footer ul li {
        padding: 0.18rem 0;
    }

    .footer a {
        transition: color 0.25s ease, transform 0.25s ease;
        display: inline-block;
    }

    .footer a.text-muted:hover {
        color: #fff !important;
        transform: translateX(3px);
    }

    .footer a.text-white {
        opacity: 0.85;
        transition: opacity 0.25s ease, transform 0.3s var(--ease-bounce, ease);
    }

    .footer a.text-white:hover {
        opacity: 1;
        transform: translateY(-4px) scale(1.12);
    }

    .footer hr {
        border-color: rgba(255, 255, 255, 0.12);
        opacity: 1;
    }

    .footer img {
        filter: brightness(0) invert(1);
        opacity: 0.92;
    }

    :global(body.dark-mode) .footer {
        background:
            radial-gradient(ellipse 70% 120% at 20% 0%, rgba(47, 107, 255, 0.12), transparent 60%),
            #060a14;
    }
</style>
